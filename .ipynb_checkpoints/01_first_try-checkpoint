    "from sklearn.linear_model import LinearRegression\n",
    "\n",
    "X = data[['分子量_kDa', '结晶度']]\n",
    "y = data['降解周期_天']\n",
    "\n",
    "model = LinearRegression()\n",
    "model.fit(X, y)\n",
    "\n",
    "print(f\"模型系数: {model.coef_}\")\n",
    "print(f\"预测新材料(350kDa, 0.45结晶度): {model.predict([[350, 0.45]])[0]:.0f}天\")\n"
